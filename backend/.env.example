# ---------------------------------------------------------
# ANDREW EXECUTIVE TWIN - MASTER ENVIRONMENT CONFIGURATION
# ---------------------------------------------------------
# Instructions: Copy this file, rename it to `.env`, and fill 
# in the actual values. If any of these are missing, the 
# associated modules will fail to run in live mode.

# --- CORE AUTHENTICATION (main.py, auth_handshake.py) ---
ANDREW_OWNER_EMAIL="your_email@domain.com"
ANDREW_OWNER_PASSWORD="your_secure_password"
ANDREW_SECRET_KEY="your_backend_api_secret_key"
ANDREW_MASTER_SECRET="your_auth_handshake_secret"

# --- THE BRAIN (persona.py, monitor.py, tutor.py, etc.) ---
GEMINI_API_KEY="your_google_gemini_api_key"
SUPER_BRAIN_API_KEY="optional_secondary_llm_key_if_used"
SILICONFLOW_API_KEY="optional_siliconflow_key_for_career_module"

# --- 9-ACCOUNT API POOL: AI STUDIO (free tier, Gemini only) ---
# Get these from aistudio.google.com → Get API Key
GEMINI_API_KEY_0="aistudio_key_account_0_brain"
GEMINI_API_KEY_1="aistudio_key_account_1_scout"
GEMINI_API_KEY_2="aistudio_key_account_2_memory"
GEMINI_API_KEY_3="aistudio_key_account_3_outreach"
GEMINI_API_KEY_4="aistudio_key_account_4_worker"
GEMINI_API_KEY_5="aistudio_key_account_5_monitor"
GEMINI_API_KEY_6="aistudio_key_account_6_finance"
GEMINI_API_KEY_7="aistudio_key_account_7_backup"
GEMINI_API_KEY_8="aistudio_key_account_8_research"

# --- 9-ACCOUNT API POOL: CLOUD CONSOLE (premium, all Google APIs) ---
# Get these from console.cloud.google.com → API & Services → Credentials
# Enable: Gemini API, Custom Search API, Gmail API, Calendar API
# Andrew defaults to AI Studio (free). Escalates to Cloud Console when:
#   - AI Studio quota exhausted
#   - Task needs Search/Gmail/Calendar APIs (only available here)
GOOGLE_CLOUD_KEY_0="console_key_account_0_brain"
GOOGLE_CLOUD_KEY_1="console_key_account_1_scout"
GOOGLE_CLOUD_KEY_2="console_key_account_2_memory"
GOOGLE_CLOUD_KEY_3="console_key_account_3_outreach"
GOOGLE_CLOUD_KEY_4="console_key_account_4_worker"
GOOGLE_CLOUD_KEY_5="console_key_account_5_monitor"
GOOGLE_CLOUD_KEY_6="console_key_account_6_finance"
GOOGLE_CLOUD_KEY_7="console_key_account_7_backup"
GOOGLE_CLOUD_KEY_8="console_key_account_8_research"

# --- EMAIL (email_nexus.py) ---
EMAIL_USER="your_email@gmail.com"
EMAIL_APP_PASSWORD="your_gmail_app_password"
EMAIL_IMAP_HOST="imap.gmail.com"
EMAIL_SMTP_HOST="smtp.gmail.com"

# --- VOICE & VISION (voice_clone.py, video_factory.py, vision.py) ---
ELEVEN_LABS_API_KEY="your_elevenlabs_api_key"
ELEVEN_LABS_VOICE_ID="21m00Tcm4TlvDq8ikWAM"
IMAGE_GEN_API_KEY="your_image_generation_key"
PEXELS_API_KEY="your_pexels_stock_video_key"

# --- TELEPHONY (voice_caller.py) ---
TWILIO_ACCOUNT_SID="your_twilio_sid"
TWILIO_AUTH_TOKEN="your_twilio_auth_token"
TWILIO_FROM_PHONE="your_twilio_phone_number"

# --- SOCIAL & GIG SCRAPERS (linkedin_agent.py, upwork_engine.py, career.py) ---
LINKEDIN_LI_AT_COOKIE="your_linkedin_session_cookie"
LINKEDIN_COOKIE="fallback_linkedin_cookie_for_career_module"
UPWORK_API_KEY="your_upwork_api_key"

# --- DEVELOPER & OPEN SOURCE (bounty_hunter.py, philanthropy.py) ---
GITHUB_PAT="your_github_personal_access_token"

# --- FINANCIAL & BLOCKCHAIN (coinbase_agent.py) ---
CDP_API_KEY_NAME="organizations/.../apiKeys/..."
CDP_API_KEY_PRIVATE_KEY="-----BEGIN EC PRIVATE KEY-----\n..."

# --- SAFETY & SECURITY ---
EMERGENCY_CONTACT_EMAIL="nextofkin@email.com"
GOOGLE_SAFE_BROWSING_KEY="your_safe_browsing_api_key"

# --- INTEGRATIONS ---
SLACK_BOT_TOKEN="xoxb-your-slack-bot-token"
GOOGLE_CALENDAR_ID="your_calendar_id@gmail.com"
PORTFOLIO_URL="https://your-deployed-portfolio.vercel.app"

# --- GOOGLE PROGRAMMABLE SEARCH ENGINE (google_search.py) ---
# Create at: https://programmablesearchengine.google.com/
# The Custom Search JSON API must be enabled on your Cloud Console keys.
GOOGLE_CSE_ID="your_search_engine_id"

